-- ============================================================
-- HOOK PLAYER CHARACTER EVENTS
-- ============================================================
local function HookCharacter(char)
    if not char then return end

    local humanoid = char:WaitForChild("Humanoid", 5)
    if humanoid then
        -- Health changes
        humanoid.HealthChanged:Connect(function(newHealth)
            AddLog("PROP", string.format("Health Changed: %.1f / %.1f", newHealth, humanoid.MaxHealth))
        end)

        -- Died
        humanoid.Died:Connect(function()
            AddLog("PROP", "Player DIED!")
        end)

        -- State changes
        humanoid.StateChanged:Connect(function(_, newState)
            AddLog("PROP", string.format("HumanoidState: %s", tostring(newState)))
        end)

        -- Movement
        humanoid.Running:Connect(function(speed)
            if speed > 0.5 then
                AddLog("PROP", string.format("Running speed: %.1f", speed))
            end
        end)

        -- Jumping
        humanoid.Jumping:Connect(function(active)
            if active then
                AddLog("PROP", "Player JUMPED")
            end
        end)
    end

    -- Touched events on character parts
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Touched:Connect(function(hit)
                if hit and not hit:IsDescendantOf(char) then
                    AddLog("TOUCH", string.format("Player part [%s] touched [%s]", part.Name, hit:GetFullName()))
                end
            end)
        end
    end
end

if Player.Character then
    HookCharacter(Player.Character)
end
Player.CharacterAdded:Connect(function(char)
    task.wait(1)
    HookCharacter(char)
    AddLog("INFO", "Character spawned/spawned")
end)

