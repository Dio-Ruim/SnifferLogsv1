-- ============================================================
-- HOOK VALUE CHANGES (IntValue, StringValue, etc.)
-- ============================================================
local ValueWatchList = {}
local MAX_WATCHED_VALUES = 200

local function WatchValue(obj)
    if ValueWatchList[obj] then return end
    if #ValueWatchList >= MAX_WATCHED_VALUES then return end
    ValueWatchList[obj] = true

    pcall(function()
        if obj:IsA("ValueBase") then
            obj.Changed:Connect(function(newValue)
                AddLog("PROP", string.format("Value[%s] %s = %s", obj.ClassName, obj:GetFullName(), tostring(newValue):sub(1, 80)))
            end)
        end
    end)
end

-- Watch common game values (leaderstats, currency, etc.)
local function ScanLeaderstats()
    local ls = Player:FindFirstChild("leaderstats")
