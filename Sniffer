local TypeColors = {
    REMOTE = Color3.fromRGB(0, 180, 255),
    FUNC = Color3.fromRGB(180, 120, 255),
    TOUCH = Color3.fromRGB(100, 255, 100),
    CLICK = Color3.fromRGB(255, 200, 50),
    PROMPT = Color3.fromRGB(255, 150, 50),
    PROP = Color3.fromRGB(200, 200, 200),
    ERROR = Color3.fromRGB(255, 60, 60),
    INFO = Color3.fromRGB(100, 200, 255),
    MODULE = Color3.fromRGB(150, 100, 255),
    SOUND = Color3.fromRGB(255, 130, 200),
}

local TypePrefixes = {
    REMOTE = "📡",
    FUNC = "⚡",
    TOUCH = "👆",
    CLICK = "🖱️",
    PROMPT = "🔔",
    PROP = "📝",
    ERROR = "❌",
    INFO = "ℹ️",
    MODULE = "📦",
    SOUND = "🔊",
}

local function SerializeArgs(args, depth)
    depth = depth or 0
    if depth > 3 then return "..." end
    local parts = {}
    for i, v in ipairs(args) do
        local t = typeof(v)
        if t == "string" then
            table.insert(parts, '"' .. (v:sub(1, 80)) .. '"')
        elseif t == "number" then
            table.insert(parts, tostring(v))
        elseif t == "boolean" then
            table.insert(parts, tostring(v))
        elseif t == "nil" then
            table.insert(parts, "nil")
        elseif t == "Vector3" then
            table.insert(parts, string.format("V3(%.2f,%.2f,%.2f)", v.X, v.Y, v.Z))
        elseif t == "CFrame" then
            local p = v.Position
            table.insert(parts, string.format("CF(%.1f,%.1f,%.1f)", p.X, p.Y, p.Z))
        elseif t == "Color3" then
            table.insert(parts, string.format("C3(%d,%d,%d)", v.R*255, v.G*255, v.B*255))
        elseif t == "Instance" then
            table.insert(parts, v:GetFullName())
        elseif t == "table" then
            local inner = SerializeArgs(v, depth + 1)
            table.insert(parts, "{" .. inner .. "}")
        elseif t == "BrickColor" then
            table.insert(parts, "BrickColor(\"" .. tostring(v) .. "\")")
        elseif t == "EnumItem" then
            table.insert(parts, tostring(v))
        elseif t == "UDim2" then
            table.insert(parts, string.format("UDim2(%.2f,%d,%.2f,%d)", v.X.Scale, v.X.Offset, v.Y.Scale, v.Y.Offset))
        else
            table.insert(parts, "<" .. t .. ">")
        end
    end
    return table.concat(parts, ", ")
end

local function AddLog(logType, text)
    if IsPaused then return end

    LineCount = LineCount + 1
    local timestamp = os.date("%H:%M:%S")
    local prefix = TypePrefixes[logType] or "•"
    local fullLine = string.format("[%s] %s %s", timestamp, prefix, text)

    table.insert(LogBuffer, fullLine)

    -- Trim buffer
    if #LogBuffer > MAX_LINES then
        table.remove(LogBuffer, 1)
    end

    -- Filter check
    local filterText = FilterBox.Text:lower()
    local passesFilter = filterText == "" or fullLine:lower():find(filterText, 1, true)
    local passesType = ActiveFilter == "ALL" or ActiveFilter == logType

    if passesFilter and passesType then
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 0, 16)
        label.AutomaticSize = Enum.AutomaticSize.Y
        label.BackgroundTransparency = 1
        label.Font = Enum.Font.RobotoMono
        label.TextSize = 12
        label.TextColor3 = TypeColors[logType] or Color3.fromRGB(200, 200, 200)
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.TextWrapped = true
        label.Text = fullLine
        label.LayoutOrder = LineCount
        label.Parent = LogFrame

        -- Auto-scroll
        task.defer(function()
            LogFrame.CanvasPosition = Vector2.new(0, LogFrame.AbsoluteCanvasSize.Y)
        end)
    end

    counterLabel.Text = tostring(LineCount) .. " logs"
end

function RefreshDisplay()
    for _, child in ipairs(LogFrame:GetChildren()) do
        if child:IsA("TextLabel") then child:Destroy() end
    end
    local filterText = FilterBox.Text:lower()
    local count = 0
    for i, line in ipairs(LogBuffer) do
        local passesFilter = filterText == "" or line:lower():find(filterText, 1, true)
        local logType = "INFO"
        for t, prefix in pairs(TypePrefixes) do
            if line:find(prefix, 1, true) then
                logType = t
                break
            end
        end
        local passesType = ActiveFilter == "ALL" or ActiveFilter == logType
        if passesFilter and passesType then
            count = count + 1
            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(1, 0, 0, 16)
            label.AutomaticSize = Enum.AutomaticSize.Y
            label.BackgroundTransparency = 1
            label.Font = Enum.Font.RobotoMono
            label.TextSize = 12
            label.TextColor3 = TypeColors[logType] or Color3.fromRGB(200, 200, 200)
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.TextWrapped = true
            label.Text = line
            label.LayoutOrder = i
            label.Parent = LogFrame
        end
    end
end

