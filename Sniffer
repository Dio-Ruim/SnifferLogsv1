-- Scan for common game patterns
local function ScanGameStructure()
    AddLog("INFO", "=== ESTRUTURA DO JOGO ===")

    -- Workspace objects
    local wsChildren = Workspace:GetChildren()
    AddLog("INFO", string.format("Workspace: %d objetos", #wsChildren))

    for _, child in ipairs(wsChildren) do
        if child:IsA("Model") then
            local descCount = #child:GetDescendants()
            AddLog("INFO", string.format("  📦 Model: %s (%d filhos)", child.Name, descCount))

            -- Check for NPCs
            local hum = child:FindFirstChildOfClass("Humanoid")
            if hum and child ~= Player.Character then
                AddLog("INFO", string.format("    🤖 NPC: %s | HP: %.0f/%.0f | Speed: %.1f", child.Name, hum.Health, hum.MaxHealth, hum.WalkSpeed))
            end
        elseif child:IsA("Folder") then
            AddLog("INFO", string.format("  📁 Folder: %s (%d filhos)", child.Name, #child:GetChildren()))
        elseif child:IsA("BasePart") and child.Name ~= "Baseplate" and child.Name ~= "Terrain" then
            AddLog("INFO", string.format("  ⬜ Part: %s | Pos: (%.1f,%.1f,%.1f)", child.Name, child.Position.X, child.Position.Y, child.Position.Z))
        end
    end

    -- ReplicatedStorage
    local rsChildren = game:GetService("ReplicatedStorage"):GetChildren()
    AddLog("INFO", string.format("ReplicatedStorage: %d objetos", #rsChildren))
    for _, child in ipairs(rsChildren) do
        local type = child.ClassName
        if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") or child:IsA("ModuleScript") then
            AddLog("INFO", string.format("  [%s] %s", type, child.Name))
        end
    end

    -- ServerScriptService (client side)
    AddLog("INFO", string.format("ServerStorage visible: %d objetos", #game:GetService("ServerStorage"):GetChildren()))
    AddLog("INFO", string.format("StarterGui: %d objetos", #game:GetService("StarterGui"):GetChildren()))
    AddLog("INFO", string.format("StarterPack: %d objetos", #game:GetService("StarterPack"):GetChildren()))
    AddLog("INFO", string.format("StarterPlayerScripts: %d objetos", #game:GetService("StarterPlayer"):FindFirstChild("StarterPlayerScripts") and #game:GetService("StarterPlayer").StarterPlayerScripts:GetChildren() or 0))
    AddLog("INFO", string.format("Lighting: %d objetos", #game:GetService("Lighting"):GetChildren()))

    -- Player info
    AddLog("INFO", string.format("Player character: %s", Player.Character and Player.Character.Name or "None"))
    if Player.Character then
        local hum = Player.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            AddLog("INFO", string.format("Humanoid: HP=%.0f/%.0f Speed=%.1f Jump=%.1f",
                hum.Health, hum.MaxHealth, hum.WalkSpeed, hum.JumpPower))
        end
        for _, obj in ipairs(Player.Character:GetChildren()) do
            if obj:IsA("Tool") then
                AddLog("INFO", string.format("  🔧 Tool equipada: %s", obj.Name))
            end
        end
    end

    AddLog("INFO", "=== FIM DA ESTRUTURA ===")
end

