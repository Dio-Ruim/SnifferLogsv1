-- Hook via __namecall on metatable
local oldNamecall
local remoteHookInstalled = false

pcall(function()
    local mt = getrawmetatable(game)
    local oldNC = mt.__namecall

    setreadonly(mt, false)

    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}

        if method == "FireServer" then
            local name = self:GetFullName()
            local argStr = SerializeArgs(args)
            AddLog("REMOTE", string.format("FireServer(%s) [%s] Args: (%s)", self.Name, name, argStr))

        elseif method == "InvokeServer" then
            local name = self:GetFullName()
            local argStr = SerializeArgs(args)
            AddLog("FUNC", string.format("InvokeServer(%s) [%s] Args: (%s)", self.Name, name, argStr))

        elseif method == "FireClient" then
            local name = self:GetFullName()
            local argStr = SerializeArgs(args)
            AddLog("REMOTE", string.format("FireClient(%s) [%s] Args: (%s)", self.Name, name, argStr))
        end

        return oldNC(self, ...)
    end)

    setreadonly(mt, true)
    remoteHookInstalled = true
end)

if remoteHookInstalled then
    AddLog("INFO", "✅ Hook de metatable instalado com sucesso!")
else
    AddLog("INFO", "⚠️ Metatable hook não disponível — usando scan de fallback")
end

-- Fallback: Scan and hook all existing remotes
local HookedRemotes = {}
local HookedFunctions = {}

local function HookRemote(remote)
    if HookedRemotes[remote] then return end
    HookedRemotes[remote] = true

    pcall(function()
        remote.OnClientEvent:Connect(function(...)
            local argStr = SerializeArgs({...})
            AddLog("REMOTE", string.format("OnClientEvent(%s) [%s] Args: (%s)", remote.Name, remote:GetFullName(), argStr))
        end)
    end)
end

local function HookRemoteFunction(func)
    if HookedFunctions[func] then return end
    HookedFunctions[func] = true

    pcall(function()
        func.OnClientInvoke = function(...)
            local argStr = SerializeArgs({...})
            AddLog("FUNC", string.format("OnClientInvoke(%s) [%s] Args: (%s)", func.Name, func:GetFullName(), argStr))
            return func.OnClientInvoke(...)
        end
    end)
end

-- Scan all descendants for remotes
local function ScanForRemotes(parent)
    for _, obj in ipairs(parent:GetDescendants()) do
        if obj:IsA("RemoteEvent") then
            HookRemote(obj)
        elseif obj:IsA("RemoteFunction") then
            HookRemoteFunction(obj)
        end
    end
end

